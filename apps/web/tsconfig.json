{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@framework/ui": ["../../packages/framework/ui/index.tsx"],
      "@framework/util": ["../../packages/framework/util/index.ts"],
      "@framework/types": ["../../packages/framework/types/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
