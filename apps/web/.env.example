# 이 파일을 .env.local로 복사한 뒤 값을 채우세요.
#
# NEXT_PUBLIC_ 접두사가 붙은 값은 빌드 시점에 클라이언트 번들로 인라인됩니다.
# 비밀값은 절대 넣지 마세요.

# [필수] SdText/SdTitle 문자열의 %c 토큰이 이 값으로 치환됩니다.
# 누락 시 빌드가 실패합니다 (apps/web/env.mjs).
NEXT_PUBLIC_COMPANY_NAME=주식회사 회사명

# [선택] 헤더 로고. 기본값: /logo.svg, "로고"
NEXT_PUBLIC_LOGO_SRC=/logo.svg
NEXT_PUBLIC_LOGO_ALT=주식회사 회사명 로고

# [선택] GitHub Pages 프로젝트 페이지처럼 하위 경로에 배포할 때만 설정합니다.
# 로컬 dev에서는 비워두세요. CI가 /<repo> 를 주입합니다.
# 주의: images.unoptimized 모드에서 Next는 <img src>에 basePath를 붙이지 않으므로
#       NEXT_PUBLIC_LOGO_SRC에도 같은 prefix를 직접 넣어야 합니다.
# NEXT_PUBLIC_BASE_PATH=/nextjs-boilerplate
