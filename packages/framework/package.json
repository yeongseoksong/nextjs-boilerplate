    "@mantine/core": "^9.2.2",
    "@mantine/hooks": "^9.2.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@tabler/icons-react": "^3.44.0"
  },
  "devDependencies": {
    "@types/react": ">=19",
    "tsup": "latest"
