{
  "name": "@yeongseoksong/framework",
  "version": "1.4.0",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "dev": "tsup --watch"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./ui": {
      "import": {
        "types": "./dist/ui/index.d.mts",
        "default": "./dist/ui/index.mjs"
      },
      "require": {
        "types": "./dist/ui/index.d.ts",
        "default": "./dist/ui/index.cjs"
      }
    },
    "./store": {
      "import": {
        "types": "./dist/store/index.d.mts",
        "default": "./dist/store/index.mjs"
      },
      "require": {
        "types": "./dist/store/index.d.ts",
        "default": "./dist/store/index.cjs"
      }
    },
    "./util": {
      "import": {
        "types": "./dist/util/index.d.mts",
        "default": "./dist/util/index.mjs"
      },
      "require": {
        "types": "./dist/util/index.d.ts",
        "default": "./dist/util/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/types/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.cjs"
      }
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "peerDependencies": {
    "@mantine/carousel": "^9.2.2",
    "@mantine/core": "^9.2.2",
    "@mantine/dates": "^9.2.2",
    "@mantine/hooks": "^9.2.2",
    "@mantine/notifications": "^9.2.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@tabler/icons-react": "^3.44.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "tsup": "latest"
  }
}
